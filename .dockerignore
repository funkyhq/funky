# Build context is the repo root (see session_store/gcp_python_postgres/Dockerfile).
# Keep the image lean and the build reproducible: ship sources, proto/, uv.lock,
# and gen/python/pyproject.toml, but never host-local venvs, caches, or the
# generated stubs (regenerated by `buf generate` inside the build).

.git/
**/.venv/
**/__pycache__/
**/*.pyc
**/*.egg-info/
**/.pytest_cache/

# Generated protobuf code — rebuilt from proto/ during the image build.
gen/python/funky/

# Example runtime data and workspace scratch.
data/
.context/

# Local Compose secrets — never bake ANTHROPIC_API_KEY into an image layer. It's
# passed to the agent-service at run time via the environment, not the build.
.env
