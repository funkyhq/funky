# Optional overrides for the frontend (copy to .env.local to use).

# Where the Vite dev server proxies the Funky REST API. Defaults to the local
# client published by docker-compose on :8000. Change this to point the dev
# server at a client running on another host/port.
# VITE_API_TARGET=http://127.0.0.1:8000

# Base URL the app prepends to API calls. Empty (the default) means same-origin,
# so requests go through the Vite proxy above. Set an absolute URL only if you
# add CORS to the client and want to skip the proxy.
# VITE_API_BASE=
