# Generated protobuf code — the .proto files are the source of truth.
# Regenerate with `buf generate`. The package shell (gen/python/pyproject.toml)
# is committed so the stubs are importable; the generated modules under it are
# not.
/gen/python/funky/

# Python
.venv/
__pycache__/
*.egg-info/

# Example runtime data (the JSONL config stores).
data/

# dependencies
node_modules/

# builds
dist/
*.tsbuildinfo

# environment — commit .env.example instead
.env
.env.*
!.env.example

# logs & runtime junk
*.log
.pnpm-debug.log*

# editor / OS noise
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# test output
coverage/